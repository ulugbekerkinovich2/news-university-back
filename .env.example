# ── Security ──────────────────────────────────────────────────────────────
SECRET_KEY=super-secret-change-this-in-production

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# ── Server ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── CORS Origins (comma-separated) ───────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
